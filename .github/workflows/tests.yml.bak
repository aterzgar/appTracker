name: Tests

on:
  push:
    branches: [ main, dev ]
  pull_request:
    branches: [ main ]

jobs:
  test:
    runs-on: ubuntu-latest
    env:
      QT_QPA_PLATFORM: offscreen

    steps:
    - uses: actions/checkout@v4

    - name: Install Dependencies
      run: |
        sudo apt-get update
        sudo apt-get install -y \
          build-essential \
          cmake \
          qtbase5-dev \
          libqt5widgets5 \
          libqt5network5 \
          libqt5test5 \
          libsqlite3-dev \
          pkg-config

    - name: Build Main Project
      run: |
        mkdir build && cd build
        cmake ..
        make -j$(nproc)

    - name: Build Tests
      run: |
        mkdir build_tests && cd build_tests
        cmake -DBUILD_TESTS=ON ..
        make -j$(nproc)

    - name: Run Tests
      run: |
        cd build_tests
        ctest --output-on-failure
